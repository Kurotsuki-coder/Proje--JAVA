<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="350.0"
      style="-fx-background-color: #2d2d30;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.client.controller.GifPickerController">

    <!-- Barre de recherche -->
    <TextField fx:id="txt_search_gif"
               promptText="🔍 Rechercher un GIF..."
               style="-fx-background-color: #3e3e42; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-padding: 8;"
               prefHeight="40.0"/>

    <!-- Grille de GIFs -->
    <ScrollPane fitToWidth="true" prefHeight="360.0"
                style="-fx-background-color: #2d2d30; -fx-background: #2d2d30;">
        <content>
            <TilePane fx:id="tile_gifs"
                      hgap="5.0" vgap="5.0"
                      prefTileWidth="100.0" prefTileHeight="100.0"
                      style="-fx-background-color: #2d2d30; -fx-padding: 5;"/>
        </content>
    </ScrollPane>
</VBox>