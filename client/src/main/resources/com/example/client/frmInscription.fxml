            <children>
                <Label layoutX="150.0" layoutY="30.0" style="-fx-text-fill:white;" text="Inscription">
                    <font>
                        <Font size="26.0" />
                    </font>
                </Label>
                <!-- Identifiant -->
                <Label layoutX="40.0" layoutY="120.0" style="-fx-text-fill:white;" text="Identifiant">
                    <font>
                        <Font size="17.0" />
                    </font>
                </Label>
                <TextField fx:id="txtIdentifiant" layoutX="40.0" layoutY="150.0" prefHeight="40" prefWidth="396.0" style=" -fx-background-color:#2b2b2b; -fx-text-fill:white; -fx-background-radius:10;" />
                <!-- Mot de passe -->
                <Label layoutX="40.0" layoutY="230.0" style="-fx-text-fill:white;" text="Mot de passe">
                    <font>
                        <Font size="17.0" />
                    </font>
                </Label>
                <PasswordField fx:id="txtMotsdepasse" layoutX="40.0" layoutY="260.0" prefHeight="40" prefWidth="396.0" style=" -fx-background-color:#2b2b2b; -fx-text-fill:white; -fx-background-radius:10;" />
