                <Label fx:id="lblMessage" layoutX="40.0" layoutY="320.0" style="-fx-text-fill:#ff5555;" />
                <!-- Boutons -->
                <Button fx:id="btnRetour" layoutX="73.0" layoutY="372.0" prefHeight="40" prefWidth="120" style=" -fx-background-color:#555; -fx-text-fill:white; -fx-background-radius:10;" text="Retour" />
                <Button fx:id="btnSInscrire" layoutX="283.0" layoutY="372.0" prefHeight="40" prefWidth="120" style=" -fx-background-color:#4CAF50; -fx-text-fill:white; -fx-background-radius:10;" text="S'inscrire" />
            </children>
        </Pane>
        <Button fx:id="btnConnexion" layoutY="0" prefHeight="60" prefWidth="310" style=" -fx-background-color:#444; -fx-text-fill:white;" text="Connexion" />
        <Button fx:id="btnInscription" layoutX="310" layoutY="0" prefHeight="60" prefWidth="310" style=" -fx-background-color:#4CAF50; -fx-text-fill:white;" text="Inscription" />
    </children>
