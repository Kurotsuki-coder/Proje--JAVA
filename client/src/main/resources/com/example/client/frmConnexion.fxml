<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="692.0" prefWidth="650.0" style="-fx-background-color:#2b2b2b;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.controller.frmConnexionController">
    <children>
        <AnchorPane layoutX="111.0" layoutY="110.0" prefHeight="524.0" prefWidth="443.0" style=" -fx-background-color:#3c3f41; -fx-background-radius:20;">
            <children>
                <Label layoutX="150.0" layoutY="30.0" style="-fx-text-fill:white;" text="Connexion">
                    <font>
                        <Font size="26.0" />
                    </font>
                </Label>
                <!-- Identifiant -->
                <Label layoutX="30.0" layoutY="120.0" style="-fx-text-fill:white;" text="Identifiant">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>
                <TextField fx:id="txtIdentifiant" layoutX="30.0" layoutY="150.0" prefHeight="40" prefWidth="380" style=" -fx-background-color:#2b2b2b; -fx-text-fill:white; -fx-background-radius:10;" />
                <!-- Mot de passe -->
                <Label layoutX="30.0" layoutY="220.0" style="-fx-text-fill:white;" text="Mot de passe">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>
                <PasswordField fx:id="txtMotsdepasse" layoutX="30.0" layoutY="250.0" prefHeight="40" prefWidth="380" style=" -fx-background-color:#2b2b2b; -fx-text-fill:white; -fx-background-radius:10;" />
                <!-- Message erreur -->
                <Label fx:id="lblMessage" layoutX="60.0" layoutY="310.0" style="-fx-text-fill:#ff5555;" />

                <!-- Mot de passe oublié -->
                <Label fx:id="lblMotdepasseOublie" layoutX="150.0" layoutY="340.0" style="-fx-text-fill:#4CAF50;" text="Mot de passe oublié ?">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
                <!-- Boutons -->
                <Button fx:id="btnQuitter" layoutX="60.0" layoutY="395.0" prefHeight="40" prefWidth="120" style=" -fx-background-color:#555; -fx-text-fill:white; -fx-background-radius:10;" text="Quitter" />
                <Button fx:id="btnSeConnecter" layoutX="240.0" layoutY="395.0" prefHeight="40" prefWidth="140" style=" -fx-background-color:#4CAF50; -fx-text-fill:white; -fx-background-radius:10;" text="Se connecter" />
            </children>
        </AnchorPane>
        <Button fx:id="btnConnexion" prefHeight="60" prefWidth="325" style=" -fx-background-color:#4CAF50; -fx-text-fill:white;" text="Connexion" />
        <Button fx:id="btnInscription" layoutX="325" prefHeight="60" prefWidth="325" style=" -fx-background-color:#444; -fx-text-fill:white;" text="Inscription" />
    </children>
</AnchorPane>